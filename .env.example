# =============================================================================
# muselab — environment variables
# Copy to .env and edit. All paths can be absolute or relative to compose dir.
# =============================================================================

# --- Required ---
# Long random string. Single-user auth token.
#   Generate:  openssl rand -hex 32
MUSELAB_TOKEN=change-me-to-a-long-random-string

# --- Docker compose ---
# Host directory exposed to the portal. Inside the container always /data.
#   Example:  /home/you/notes
ARCHIVE_DIR=./data

# Host location of Claude CLI credentials (from `claude login`).
# Auto-detected via ${HOME}/.claude; override only if non-standard.
# CLAUDE_HOME=/custom/path/.claude

# --- Optional ---
# Host port (container always listens on 8765).
MUSELAB_PORT=8765

# Host interface to bind. Defaults to 127.0.0.1 = localhost-only (safe default
# for the per-OS desktop installers). Set to 0.0.0.0 to expose on LAN/VPS —
# then you MUST also open the firewall and trust everyone on that network with
# your MUSELAB_TOKEN. Docker compose always binds 0.0.0.0 inside the container
# (irrelevant here; just don't `ports:` to a public interface on the host).
MUSELAB_HOST=127.0.0.1

# Docker only: host interface the published port binds to (used by
# docker-compose.yml as `${MUSELAB_BIND}:8765:8765`). Defaults to 127.0.0.1 =
# loopback-only. Set to 0.0.0.0 to expose on LAN/VPS — then put a reverse proxy
# / firewall in front. This is the Docker counterpart of MUSELAB_HOST above
# (which is for running uvicorn directly, not in a container).
# MUSELAB_BIND=127.0.0.1

# Default model — leave UNSET to let the frontend auto-pick the first
# configured provider (e.g. DeepSeek if only DEEPSEEK_API_KEY is filled).
# Set explicitly only when you want a specific model AND the corresponding
# provider is configured. Otherwise the chat will 401 on first send.
# MUSELAB_MODEL=claude-sonnet-4-6

# Anthropic prompt cache lifetime. Default `1h` opts the spawned claude CLI
# into 1-hour cache TTL — long sessions stay cheap to resume even after
# coffee-break-length idles. Anthropic's global default was silently
# regressed from 1h to 5min on 2026-03-06 (claude-code issue #46829),
# which made the "first turn after >5 min idle" expensive for everyone.
# We opt back into 1h. Trade-off: cache_creation tokens cost 2× base price
# (vs 1.25× for 5m), so once-per-day sessions seed slightly more expensively;
# any session touched ≥2 times in an hour comes out ahead.
# Values: 1h (default, recommended) / 5m / empty (leave CLI default alone).
MUSELAB_PROMPT_CACHE_TTL=1h

# --- Optional: alternative providers (Anthropic-compatible endpoints) ---
# Set any to enable that provider in the model picker. All routed via the
# claude-agent-sdk directly — vendor must expose an `/anthropic` endpoint
# (DeepSeek / GLM / MiniMax all do). Full SDK feature parity: tools, MCP,
# skills, streaming, thinking — same loop as Anthropic, just different host.
DEEPSEEK_API_KEY=
ZHIPUAI_API_KEY=         # 智谱 GLM 5.1 / GLM 5 / GLM 5 Air
MINIMAX_API_KEY=         # MiniMax M2.1 / M2.5 / M2.7 (国内) — minimaxi.com
MINIMAX_INTL_API_KEY=    # MiniMax 国际站 — separate key, minimax.io
MOONSHOT_API_KEY=        # Kimi K2 / K2.5 / K2.6 / K2 Thinking
DASHSCOPE_API_KEY=       # Qwen3 / 3.5 / 3.6 series (Alibaba) — same key for 国内 + 国际
XIAOMI_MIMO_API_KEY=     # Xiaomi MiMo V2.5 Pro / V2.5 / V2 Flash
QIANFAN_API_KEY=         # Baidu Qianfan — ERNIE 5.0 / 4.5 Turbo / X1.1
CODEX_GATEWAY_API_KEY=   # Local Codex Gateway token — use the same api-key as examples/cli-proxy-muselab.config.yaml
# OpenAI-compatible upstream base. It may be either the server root or /v1;
# MuseLab normalizes it to POST <base>/v1/chat/completions internally.
# CODEX_GATEWAY_BASE_URL=http://127.0.0.1:8317/v1

# Optional lightweight OpenAI-compatible model for automatic session titles.
# MUSELAB_TITLE_LLM_URL=http://127.0.0.1:8000/v1/chat/completions
# MUSELAB_TITLE_LLM_API_KEY=
# MUSELAB_TITLE_LLM_MODEL=Qwen3.6-27B
# Image generation is separate from chat providers. MUSELAB_IMAGE_PROVIDER=auto
# uses OpenAI Image API when a key is present. Local Codex imagegen must be
# explicitly enabled because it runs a local codex subprocess.
MUSELAB_IMAGE_PROVIDER=auto   # auto | openai | codex_imagegen
OPENAI_IMAGE_API_KEY=    # gpt-image-2 / Image API key
CODEX_IMAGEGEN_ENABLED=false
CODEX_IMAGEGEN_TIMEOUT_SECONDS=300
# Optional base URL overrides for self-hosted / proxied / regional mirrors.
# These point at each vendor's Anthropic-compatible endpoint (not /v1 OpenAI).
# Leave blank to use the public default; set to a full URL to redirect every
# stream + probe call. Takes effect on the next stream — no restart needed.
# DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
# ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/anthropic
# MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
# MOONSHOT_BASE_URL=https://api.moonshot.cn/anthropic
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/apps/anthropic   # 国内默认；国际站选 "Qwen (国际)" 分组或改 dashscope-intl.aliyuncs.com
# XIAOMI_MIMO_BASE_URL=https://api.xiaomimimo.com/anthropic
# QIANFAN_BASE_URL=https://qianfan.baidubce.com/anthropic
# CODEX_GATEWAY_BASE_URL=http://127.0.0.1:8317
# OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1

# --- Native (non-Docker) only ---
# Absolute host path of the archive root when running `uvicorn ...` directly.
# Ignored when running via docker-compose.
MUSELAB_ROOT=/home/you/notes

# =============================================================================
# Optional tuning — all have sensible defaults, override only when you need to.
# =============================================================================

# Soft monthly budget in USD — used to color the cost badge red and
# show "X% of budget" in the cost dashboard. Does NOT hard-stop streams
# (no enforcement at request time). Default 0 = disable the indicator.
# Also editable via Settings UI.
# MUSELAB_BUDGET_USD=20

# Max single upload size (MiB). Default 100. Bump for big PDFs / xlsx,
# lower to enforce a stricter ceiling.
# MUSELAB_MAX_UPLOAD_MB=100

# Max conversation turns per chat session before the SDK auto-cuts.
# Default unset = no muselab-imposed limit (SDK's own default applies).
# Lower this to cap long debugging threads from spiralling. No longer
# exposed in the Settings UI (2026-05-28) — env-only escape hatch.
# MUSELAB_MAX_TURNS=80

# Extended-thinking token budget (Claude only). Default 10000.
# Set to 0 to disable thinking. Higher = better at math/planning, slower + costlier.
# No longer exposed in the Settings UI (2026-05-28) — env-only escape hatch.
# MUSELAB_THINKING_BUDGET=10000

# SDK client pool size. Default 3 — concurrent streams beyond this queue.
# Bump if you actually run many parallel streams (rare for single user).
# MUSELAB_CLIENT_POOL_CAP=3

# Comma-separated list to hide providers from the model picker UI.
# A provider is identified by its FIRST model id (the stable per-provider
# key the backend matches on — NOT a short name like "qianfan").
# Valid values (one per provider): deepseek-v4-pro, glm-5.1, minimax-m2.7,
#   minimax-intl:minimax-m2.7, kimi-k2.6, qwen3.6-plus, qwen-intl:qwen3.6-plus,
#   mimo-v2.5-pro, ernie-5.0
# (Anthropic/Claude can't be disabled this way; it's gated by OAuth/API key.)
# Example — hide Qianfan + Xiaomi MiMo:
# MUSELAB_DISABLED_PROVIDERS=ernie-5.0,mimo-v2.5-pro

# Disable Claude skills (rules / personal-research / doc / etc.) entirely.
# Set to 1 if a skill is misbehaving and you want to bypass without uninstall.
# MUSELAB_DISABLE_SKILLS=0

# Prune sessions whose JSONL is empty (e.g. crashed before first turn).
# Default off — KEEP IT OFF. ⚠️ DATA LOSS RISK: the "empty" check keys on
# message_count, which the backend does not reliably write, so real sessions
# (with a full transcript) can be misdetected as empty and hard-deleted — JSONL
# and all — on every service restart. Only enable if you understand this.
# MUSELAB_PRUNE_EMPTY_SESSIONS=false

# Install-time language hint for the install scripts (intake prompts +
# default CLAUDE.md skeleton). Auto-detected from LANG / LC_ALL otherwise.
# NOT read by the running backend — the frontend's language toggle in
# Settings is independent of this. Export before running install-*.sh.
# MUSELAB_LOCALE=zh

# Push notification VAPID subject (mailto: or https:// URL). Required only
# if you enable push subscriptions in settings.
# MUSELAB_VAPID_SUBJECT=mailto:you@example.com

# Default model / permission for fresh installs (settings UI overrides).
# MUSELAB_DEFAULT_MODEL=claude-sonnet-4-6
# MUSELAB_DEFAULT_PERMISSION=bypassPermissions

# Days to keep soft-deleted files in <ROOT>/.muselab-dustbin/ before
# auto-purge (runs on startup). Default 30, matching macOS Finder /
# GNOME. Set to 0 to disable auto-purge (trash grows forever).
# MUSELAB_TRASH_TTL_DAYS=30

# Alternative .env location (auto-detected from cwd by default). Used by
# the settings API when persisting key/model changes.
# MUSELAB_ENV_PATH=/etc/muselab/.env
