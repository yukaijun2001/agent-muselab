.venv/
__pycache__/
*.pyc
.env
.env.*
!.env.example
.router-token
# Private personal-data blacklist for scripts/lint.sh leak-scan (Check 4).
# Holds the maintainer's own identifying literals (real name, employer, home
# city, target-company names) so the leak-scan can refuse to commit them. It is
# private by definition and MUST NEVER be committed — see SECURITY note in
# scripts/lint.sh. lint.sh hard-fails if this file is ever git-tracked.
scripts/.leak-blacklist
.DS_Store
sessions/
sessions.bak-*/
mcp.json
# Runtime user config persisted by Settings → model editor (endpoints.py
# OVERRIDES_PATH, "next to mcp.json") — per-instance state, same class as
# mcp.json above; never ship a maintainer's copy in the repo.
provider_overrides.json
# Local Codex / gateway runtime state — credentials, logs, and tokens are never
# part of the open-source artifact.
.codex/
.cli-proxy-muselab/
.muselab/codex-gateway/
.muselab/imagegen/
codex-gateway/.env
codex-gateway/*.log
data/
# frontend/data/ ships tracked static JS modules (i18n alternatives, slash
# commands, etc.); carve out from the generic data/ rule above.
!frontend/data/
!frontend/data/**
*.egg-info/
dist/
build/
.ruff_cache/
.mypy_cache/
.pytest_cache/
.vscode/
.idea/
*.log
node_modules/

